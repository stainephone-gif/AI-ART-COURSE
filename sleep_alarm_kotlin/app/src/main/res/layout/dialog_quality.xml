<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:gravity="center"
    android:padding="32dp" android:background="@color/midnight">

    <View android:layout_width="40dp" android:layout_height="4dp"
          android:layout_gravity="center_horizontal" android:background="@drawable/chip_bg"
          android:layout_marginBottom="24dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:text="Как вы поспали?" android:textSize="29sp"
              android:textColor="@color/frost_white" android:fontFamily="sans-serif-light"
              android:layout_marginBottom="20dp"/>

    <TextView android:id="@+id/tvQualityEmoji" android:layout_width="wrap_content"
              android:layout_height="wrap_content" android:text="😐" android:textSize="54sp"
              android:layout_marginBottom="8dp"/>
    <TextView android:id="@+id/tvQualityLabel" android:layout_width="wrap_content"
              android:layout_height="wrap_content" android:text="Нормально" android:textSize="16sp"
              android:textColor="@color/whisper_gray" android:fontFamily="sans-serif-light"
              android:layout_marginBottom="24dp"/>

    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                  android:orientation="horizontal" android:layout_marginBottom="36dp">
        <TextView android:id="@+id/star1" android:layout_width="48dp" android:layout_height="48dp"
                  android:text="⭐" android:textSize="30sp" android:gravity="center"
                  android:alpha="0.3" android:clickable="true" android:focusable="true"/>
        <TextView android:id="@+id/star2" android:layout_width="48dp" android:layout_height="48dp"
                  android:text="⭐" android:textSize="30sp" android:gravity="center"
                  android:alpha="0.3" android:clickable="true" android:focusable="true"/>
        <TextView android:id="@+id/star3" android:layout_width="48dp" android:layout_height="48dp"
                  android:text="⭐" android:textSize="30sp" android:gravity="center"
                  android:alpha="1.0" android:clickable="true" android:focusable="true"/>
        <TextView android:id="@+id/star4" android:layout_width="48dp" android:layout_height="48dp"
                  android:text="⭐" android:textSize="30sp" android:gravity="center"
                  android:alpha="0.3" android:clickable="true" android:focusable="true"/>
        <TextView android:id="@+id/star5" android:layout_width="48dp" android:layout_height="48dp"
                  android:text="⭐" android:textSize="30sp" android:gravity="center"
                  android:alpha="0.3" android:clickable="true" android:focusable="true"/>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnQualitySave"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:text="Сохранить" android:textColor="@color/midnight"
        android:textSize="15sp" android:fontFamily="sans-serif-light"
        app:backgroundTint="@color/frost_white" app:cornerRadius="75dp" app:elevation="0dp"
        android:layout_marginBottom="8dp"/>
</LinearLayout>
