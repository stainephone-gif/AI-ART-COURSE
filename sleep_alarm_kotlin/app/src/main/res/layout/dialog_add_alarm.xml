<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/midnight">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="@drawable/chip_bg"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Будильник"
        android:textSize="29sp"
        android:textColor="@color/frost_white"
        android:fontFamily="sans-serif-light"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <!-- Time picker — large, minimal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="24dp">

        <NumberPicker
            android:id="@+id/npHour"
            android:layout_width="90dp"
            android:layout_height="140dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=":"
            android:textSize="48sp"
            android:textColor="@color/frost_white"
            android:fontFamily="sans-serif-thin"
            android:paddingHorizontal="8dp"/>

        <NumberPicker
            android:id="@+id/npMinute"
            android:layout_width="90dp"
            android:layout_height="140dp"/>
    </LinearLayout>

    <!-- Label input -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:text="НАЗВАНИЕ" android:textSize="10sp" android:letterSpacing="0.15"
              android:textColor="@color/whisper_gray" android:layout_marginBottom="6dp"/>
    <EditText
        android:id="@+id/etLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/field_bg"
        android:hint="Например: Работа"
        android:textColor="@color/frost_white"
        android:textColorHint="@color/whisper_gray"
        android:padding="14dp"
        android:textSize="15sp"
        android:fontFamily="sans-serif-light"
        android:inputType="textCapSentences"
        android:layout_marginBottom="20dp"/>

    <!-- Repeat days -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:text="ПОВТОР" android:textSize="10sp" android:letterSpacing="0.15"
              android:textColor="@color/whisper_gray" android:layout_marginBottom="10dp"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                  android:orientation="horizontal" android:layout_marginBottom="20dp">
        <Button android:id="@+id/btnMon" android:layout_width="0dp" android:layout_height="40dp"
            android:layout_weight="1" android:text="Пн" style="@style/DayBtn" android:layout_marginEnd="3dp"/>
        <Button android:id="@+id/btnTue" android:layout_width="0dp" android:layout_height="40dp"
            android:layout_weight="1" android:text="Вт" style="@style/DayBtn" android:layout_marginEnd="3dp"/>
        <Button android:id="@+id/btnWed" android:layout_width="0dp" android:layout_height="40dp"
            android:layout_weight="1" android:text="Ср" style="@style/DayBtn" android:layout_marginEnd="3dp"/>
        <Button android:id="@+id/btnThu" android:layout_width="0dp" android:layout_height="40dp"
            android:layout_weight="1" android:text="Чт" style="@style/DayBtn" android:layout_marginEnd="3dp"/>
        <Button android:id="@+id/btnFri" android:layout_width="0dp" android:layout_height="40dp"
            android:layout_weight="1" android:text="Пт" style="@style/DayBtn" android:layout_marginEnd="3dp"/>
        <Button android:id="@+id/btnSat" android:layout_width="0dp" android:layout_height="40dp"
            android:layout_weight="1" android:text="Сб" style="@style/DayBtn" android:layout_marginEnd="3dp"/>
        <Button android:id="@+id/btnSun" android:layout_width="0dp" android:layout_height="40dp"
            android:layout_weight="1" android:text="Вс" style="@style/DayBtn"/>
    </LinearLayout>

    <!-- Smart alarm toggle -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                  android:orientation="horizontal" android:gravity="center_vertical"
                  android:background="@drawable/frosted_card" android:padding="16dp"
                  android:layout_marginBottom="8dp">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                      android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                      android:text="Умный будильник"
                      android:textColor="@color/frost_white" android:textSize="15sp"
                      android:fontFamily="sans-serif-light"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                      android:text="Будит в лёгкой фазе сна"
                      android:textColor="@color/whisper_gray" android:textSize="12sp"
                      android:fontFamily="sans-serif-light"/>
        </LinearLayout>
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swSmart"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            app:thumbTint="@color/midnight" app:trackTint="@color/frost_white"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>
    </LinearLayout>

    <!-- Smart window -->
    <LinearLayout android:id="@+id/rowSmartWindow"
                  android:layout_width="match_parent" android:layout_height="wrap_content"
                  android:orientation="horizontal" android:gravity="center_vertical"
                  android:paddingHorizontal="4dp" android:layout_marginBottom="8dp"
                  android:visibility="gone">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                  android:text="Окно:" android:textColor="@color/whisper_gray" android:textSize="12sp"
                  android:layout_marginEnd="10dp" android:fontFamily="sans-serif-light"/>
        <SeekBar android:id="@+id/sbWindow" android:layout_width="0dp"
                 android:layout_height="wrap_content" android:layout_weight="1"
                 android:max="2" android:progress="2"
                 android:progressTint="@color/frost_white" android:thumbTint="@color/frost_white"/>
        <TextView android:id="@+id/tvWindowVal" android:layout_width="60dp"
                  android:layout_height="wrap_content" android:text="30 мин"
                  android:textColor="@color/frost_white" android:textSize="12sp"
                  android:gravity="end" android:fontFamily="sans-serif-light"/>
    </LinearLayout>

    <!-- Gradual alarm toggle -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                  android:orientation="horizontal" android:gravity="center_vertical"
                  android:background="@drawable/frosted_card" android:padding="16dp"
                  android:layout_marginBottom="28dp">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                      android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                      android:text="Плавный будильник"
                      android:textColor="@color/frost_white" android:textSize="15sp"
                      android:fontFamily="sans-serif-light"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                      android:text="Громкость нарастает 2 минуты"
                      android:textColor="@color/whisper_gray" android:textSize="12sp"
                      android:fontFamily="sans-serif-light"/>
        </LinearLayout>
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swGradual"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            app:thumbTint="@color/midnight" app:trackTint="@color/frost_white"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>
    </LinearLayout>

    <!-- Actions — pill buttons -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                  android:orientation="horizontal" android:layout_marginBottom="16dp">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            android:layout_width="0dp" android:layout_height="52dp"
            android:layout_weight="1" android:text="Отмена"
            android:textColor="@color/frost_white" android:textSize="15sp"
            android:fontFamily="sans-serif-light"
            android:layout_marginEnd="10dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="#33FFFFFF" app:strokeWidth="1dp"
            app:cornerRadius="75dp"
            app:backgroundTint="@android:color/transparent"
            app:elevation="0dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="0dp" android:layout_height="52dp"
            android:layout_weight="1" android:text="Сохранить"
            android:textColor="@color/midnight" android:textSize="15sp"
            app:backgroundTint="@color/frost_white"
            app:cornerRadius="75dp" app:elevation="0dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>
    </LinearLayout>
</LinearLayout>
