<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                  android:text="Звуки сна" android:textSize="28sp"
                  android:textColor="@color/white" android:fontFamily="sans-serif-medium"
                  android:layout_marginBottom="4dp" android:layout_marginTop="8dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                  android:text="Нажмите для воспроизведения"
                  android:textSize="13sp" android:textColor="@color/muted"
                  android:layout_marginBottom="20dp"/>

        <!-- 2-column grid of sound cards -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:orientation="horizontal" android:layout_marginBottom="12dp">
            <androidx.cardview.widget.CardView android:id="@+id/cardWhite"
                android:layout_width="0dp" android:layout_height="100dp"
                android:layout_weight="1" android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@color/sound_card_bg" app:cardCornerRadius="16dp" app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                              android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                              android:text="〰️" android:textSize="32sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                              android:text="Белый шум" android:textColor="@color/sub" android:textSize="13sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView android:id="@+id/cardBrown"
                android:layout_width="0dp" android:layout_height="100dp"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/sound_card_bg" app:cardCornerRadius="16dp" app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                              android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                              android:text="🌊" android:textSize="32sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                              android:text="Тёмный шум" android:textColor="@color/sub" android:textSize="13sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:orientation="horizontal" android:layout_marginBottom="12dp">
            <androidx.cardview.widget.CardView android:id="@+id/cardRain"
                android:layout_width="0dp" android:layout_height="100dp"
                android:layout_weight="1" android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@color/sound_card_bg" app:cardCornerRadius="16dp" app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                              android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                              android:text="🌧️" android:textSize="32sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                              android:text="Дождь" android:textColor="@color/sub" android:textSize="13sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView android:id="@+id/cardForest"
                android:layout_width="0dp" android:layout_height="100dp"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/sound_card_bg" app:cardCornerRadius="16dp" app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                              android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                              android:text="🌲" android:textSize="32sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                              android:text="Лес" android:textColor="@color/sub" android:textSize="13sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:orientation="horizontal" android:layout_marginBottom="20dp">
            <androidx.cardview.widget.CardView android:id="@+id/cardOcean"
                android:layout_width="0dp" android:layout_height="100dp"
                android:layout_weight="1" android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@color/sound_card_bg" app:cardCornerRadius="16dp" app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                              android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                              android:text="🌊" android:textSize="32sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                              android:text="Океан" android:textColor="@color/sub" android:textSize="13sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView android:id="@+id/cardFan"
                android:layout_width="0dp" android:layout_height="100dp"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/sound_card_bg" app:cardCornerRadius="16dp" app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                              android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                              android:text="💨" android:textSize="32sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                              android:text="Вентилятор" android:textColor="@color/sub" android:textSize="13sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Volume -->
        <SeekBar android:id="@+id/seekVolume"
                 android:layout_width="match_parent" android:layout_height="wrap_content"
                 android:max="100" android:progress="70"
                 android:progressTint="@color/accent" android:thumbTint="@color/accent"
                 android:layout_marginBottom="20dp" android:visibility="gone"/>

        <!-- Timer card -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface" app:cardCornerRadius="16dp" app:cardElevation="0dp"
            android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                          android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                              android:orientation="horizontal" android:gravity="center_vertical"
                              android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                              android:layout_weight="1" android:text="⏱️ Таймер выключения"
                              android:textColor="@color/white" android:textSize="15sp"/>
                    <TextView android:id="@+id/tvTimerStatus"
                              android:layout_width="wrap_content" android:layout_height="wrap_content"
                              android:text="Не выключать" android:textColor="@color/muted" android:textSize="13sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                              android:orientation="horizontal">
                    <Button android:id="@+id/btnTimer0" android:layout_width="0dp"
                        android:layout_height="36dp" android:layout_weight="1"
                        android:text="∞" android:textSize="14sp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        app:strokeColor="@color/dimmed" android:textColor="@color/muted"
                        android:layout_marginEnd="4dp"/>
                    <Button android:id="@+id/btnTimer15" android:layout_width="0dp"
                        android:layout_height="36dp" android:layout_weight="1"
                        android:text="15м" android:textSize="12sp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        app:strokeColor="@color/dimmed" android:textColor="@color/muted"
                        android:layout_marginEnd="4dp"/>
                    <Button android:id="@+id/btnTimer30" android:layout_width="0dp"
                        android:layout_height="36dp" android:layout_weight="1"
                        android:text="30м" android:textSize="12sp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        app:strokeColor="@color/dimmed" android:textColor="@color/muted"
                        android:layout_marginEnd="4dp"/>
                    <Button android:id="@+id/btnTimer60" android:layout_width="0dp"
                        android:layout_height="36dp" android:layout_weight="1"
                        android:text="60м" android:textSize="12sp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        app:strokeColor="@color/dimmed" android:textColor="@color/muted"
                        android:layout_marginEnd="4dp"/>
                    <Button android:id="@+id/btnTimer90" android:layout_width="0dp"
                        android:layout_height="36dp" android:layout_weight="1"
                        android:text="90м" android:textSize="12sp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        app:strokeColor="@color/dimmed" android:textColor="@color/muted"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
