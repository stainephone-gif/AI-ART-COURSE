<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/midnight">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                  android:orientation="vertical" android:padding="16dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                  android:text="Звуки сна" android:textSize="39sp"
                  android:textColor="@color/frost_white" android:fontFamily="sans-serif-light"
                  android:letterSpacing="-0.01"
                  android:layout_marginBottom="4dp" android:layout_marginTop="12dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                  android:text="Нажмите для воспроизведения"
                  android:textSize="14sp" android:textColor="@color/whisper_gray"
                  android:fontFamily="sans-serif-light"
                  android:layout_marginBottom="24dp"/>

        <!-- 2-col sound grid -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:orientation="horizontal" android:layout_marginBottom="10dp">
            <LinearLayout android:id="@+id/cardWhite"
                android:layout_width="0dp" android:layout_height="110dp" android:layout_weight="1"
                android:layout_marginEnd="8dp" android:background="@drawable/frosted_card"
                android:orientation="vertical" android:gravity="center" android:clickable="true"
                android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:text="〰️" android:textSize="30sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:text="Белый шум" android:textColor="@color/whisper_gray"
                          android:textSize="13sp" android:fontFamily="sans-serif-light"
                          android:layout_marginTop="6dp"/>
            </LinearLayout>
            <LinearLayout android:id="@+id/cardBrown"
                android:layout_width="0dp" android:layout_height="110dp" android:layout_weight="1"
                android:background="@drawable/frosted_card"
                android:orientation="vertical" android:gravity="center" android:clickable="true"
                android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:text="🌊" android:textSize="30sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:text="Тёмный шум" android:textColor="@color/whisper_gray"
                          android:textSize="13sp" android:fontFamily="sans-serif-light"
                          android:layout_marginTop="6dp"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:orientation="horizontal" android:layout_marginBottom="10dp">
            <LinearLayout android:id="@+id/cardRain"
                android:layout_width="0dp" android:layout_height="110dp" android:layout_weight="1"
                android:layout_marginEnd="8dp" android:background="@drawable/frosted_card"
                android:orientation="vertical" android:gravity="center" android:clickable="true"
                android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:text="🌧️" android:textSize="30sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:text="Дождь" android:textColor="@color/whisper_gray"
                          android:textSize="13sp" android:fontFamily="sans-serif-light"
                          android:layout_marginTop="6dp"/>
            </LinearLayout>
            <LinearLayout android:id="@+id/cardForest"
                android:layout_width="0dp" android:layout_height="110dp" android:layout_weight="1"
                android:background="@drawable/frosted_card"
                android:orientation="vertical" android:gravity="center" android:clickable="true"
                android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:text="🌲" android:textSize="30sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:text="Лес" android:textColor="@color/whisper_gray"
                          android:textSize="13sp" android:fontFamily="sans-serif-light"
                          android:layout_marginTop="6dp"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:orientation="horizontal" android:layout_marginBottom="24dp">
            <LinearLayout android:id="@+id/cardOcean"
                android:layout_width="0dp" android:layout_height="110dp" android:layout_weight="1"
                android:layout_marginEnd="8dp" android:background="@drawable/frosted_card"
                android:orientation="vertical" android:gravity="center" android:clickable="true"
                android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:text="🌊" android:textSize="30sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:text="Океан" android:textColor="@color/whisper_gray"
                          android:textSize="13sp" android:fontFamily="sans-serif-light"
                          android:layout_marginTop="6dp"/>
            </LinearLayout>
            <LinearLayout android:id="@+id/cardFan"
                android:layout_width="0dp" android:layout_height="110dp" android:layout_weight="1"
                android:background="@drawable/frosted_card"
                android:orientation="vertical" android:gravity="center" android:clickable="true"
                android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:text="💨" android:textSize="30sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:text="Вентилятор" android:textColor="@color/whisper_gray"
                          android:textSize="13sp" android:fontFamily="sans-serif-light"
                          android:layout_marginTop="6dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Volume -->
        <SeekBar android:id="@+id/seekVolume" android:layout_width="match_parent"
                 android:layout_height="wrap_content" android:max="100" android:progress="70"
                 android:progressTint="@color/frost_white" android:thumbTint="@color/frost_white"
                 android:layout_marginBottom="24dp" android:visibility="gone"/>

        <!-- Timer -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:orientation="vertical" android:background="@drawable/frosted_card"
                      android:padding="20dp" android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                          android:orientation="horizontal" android:gravity="center_vertical"
                          android:layout_marginBottom="14dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                          android:layout_weight="1" android:text="Таймер выключения"
                          android:textColor="@color/frost_white" android:textSize="15sp"
                          android:fontFamily="sans-serif-light"/>
                <TextView android:id="@+id/tvTimerStatus" android:layout_width="wrap_content"
                          android:layout_height="wrap_content" android:text="Не выключать"
                          android:textColor="@color/whisper_gray" android:textSize="12sp"
                          android:fontFamily="sans-serif-light"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                          android:orientation="horizontal">
                <Button android:id="@+id/btnTimer0" android:layout_width="0dp"
                    android:layout_height="36dp" android:layout_weight="1" android:text="∞"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="#33FFFFFF" app:strokeWidth="1dp" app:cornerRadius="75dp"
                    android:textColor="@color/frost_white" android:textSize="13sp"
                    app:backgroundTint="@android:color/transparent" app:elevation="0dp"
                    android:layout_marginEnd="4dp" xmlns:app="http://schemas.android.com/apk/res-auto"/>
                <Button android:id="@+id/btnTimer15" android:layout_width="0dp"
                    android:layout_height="36dp" android:layout_weight="1" android:text="15м"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="#33FFFFFF" app:strokeWidth="1dp" app:cornerRadius="75dp"
                    android:textColor="@color/whisper_gray" android:textSize="12sp"
                    app:backgroundTint="@android:color/transparent" app:elevation="0dp"
                    android:layout_marginEnd="4dp" xmlns:app="http://schemas.android.com/apk/res-auto"/>
                <Button android:id="@+id/btnTimer30" android:layout_width="0dp"
                    android:layout_height="36dp" android:layout_weight="1" android:text="30м"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="#33FFFFFF" app:strokeWidth="1dp" app:cornerRadius="75dp"
                    android:textColor="@color/whisper_gray" android:textSize="12sp"
                    app:backgroundTint="@android:color/transparent" app:elevation="0dp"
                    android:layout_marginEnd="4dp" xmlns:app="http://schemas.android.com/apk/res-auto"/>
                <Button android:id="@+id/btnTimer60" android:layout_width="0dp"
                    android:layout_height="36dp" android:layout_weight="1" android:text="60м"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="#33FFFFFF" app:strokeWidth="1dp" app:cornerRadius="75dp"
                    android:textColor="@color/whisper_gray" android:textSize="12sp"
                    app:backgroundTint="@android:color/transparent" app:elevation="0dp"
                    android:layout_marginEnd="4dp" xmlns:app="http://schemas.android.com/apk/res-auto"/>
                <Button android:id="@+id/btnTimer90" android:layout_width="0dp"
                    android:layout_height="36dp" android:layout_weight="1" android:text="90м"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="#33FFFFFF" app:strokeWidth="1dp" app:cornerRadius="75dp"
                    android:textColor="@color/whisper_gray" android:textSize="12sp"
                    app:backgroundTint="@android:color/transparent" app:elevation="0dp"
                    xmlns:app="http://schemas.android.com/apk/res-auto"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
