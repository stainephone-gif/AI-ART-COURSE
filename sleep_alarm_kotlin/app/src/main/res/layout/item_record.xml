<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginBottom="8dp" android:background="@drawable/frosted_card"
    android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">

    <TextView android:id="@+id/tvRecordEmoji" android:layout_width="40dp"
              android:layout_height="wrap_content" android:textSize="24sp" android:gravity="center"/>

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                  android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="10dp">
        <TextView android:id="@+id/tvRecordDate" android:layout_width="wrap_content"
                  android:layout_height="wrap_content" android:textSize="14sp"
                  android:textColor="@color/frost_white" android:fontFamily="sans-serif-light"/>
        <TextView android:id="@+id/tvRecordTimes" android:layout_width="wrap_content"
                  android:layout_height="wrap_content" android:textSize="12sp"
                  android:textColor="@color/whisper_gray" android:fontFamily="sans-serif-light"
                  android:layout_marginTop="2dp"/>
    </LinearLayout>

    <TextView android:id="@+id/tvRecordStars" android:layout_width="wrap_content"
              android:layout_height="wrap_content" android:textSize="11sp"
              android:textColor="#AAFFFFFF"/>
</LinearLayout>
