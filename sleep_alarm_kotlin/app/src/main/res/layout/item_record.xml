<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                  android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">

        <TextView android:id="@+id/tvRecordEmoji"
                  android:layout_width="40dp" android:layout_height="wrap_content"
                  android:textSize="24sp" android:gravity="center"/>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                      android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
            <TextView android:id="@+id/tvRecordDate"
                      android:layout_width="wrap_content" android:layout_height="wrap_content"
                      android:textSize="14sp" android:textColor="@color/text"/>
            <TextView android:id="@+id/tvRecordTimes"
                      android:layout_width="wrap_content" android:layout_height="wrap_content"
                      android:textSize="12sp" android:textColor="@color/muted" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <TextView android:id="@+id/tvRecordStars"
                  android:layout_width="wrap_content" android:layout_height="wrap_content"
                  android:textSize="12sp"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
