<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/midnight">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                  android:orientation="vertical" android:padding="16dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                  android:text="Статистика" android:textSize="39sp"
                  android:textColor="@color/frost_white" android:fontFamily="sans-serif-light"
                  android:letterSpacing="-0.01"
                  android:layout_marginTop="12dp" android:layout_marginBottom="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                  android:text="История качества сна"
                  android:textSize="14sp" android:textColor="@color/whisper_gray"
                  android:fontFamily="sans-serif-light" android:layout_marginBottom="24dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRate"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="Оценить сон"
            android:textColor="@color/midnight" android:textSize="15sp"
            android:fontFamily="sans-serif-light"
            app:backgroundTint="@color/frost_white"
            app:cornerRadius="75dp" app:elevation="0dp"
            android:layout_marginBottom="28dp"/>

        <!-- Empty -->
        <LinearLayout android:id="@+id/groupEmpty"
                      android:layout_width="match_parent" android:layout_height="260dp"
                      android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                      android:text="🛌" android:textSize="48sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                      android:text="Нет данных" android:textSize="18sp"
                      android:textColor="@color/whisper_gray" android:fontFamily="sans-serif-light"
                      android:layout_marginTop="12dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                      android:text="Оцените качество сна каждое утро"
                      android:textSize="13sp" android:textColor="@color/misty_gray"
                      android:fontFamily="sans-serif-light" android:layout_marginTop="6dp"
                      android:gravity="center"/>
        </LinearLayout>

        <!-- Content -->
        <LinearLayout android:id="@+id/groupContent"
                      android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:orientation="vertical" android:visibility="gone">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                          android:orientation="horizontal" android:layout_marginBottom="24dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="90dp"
                    android:layout_weight="1" android:layout_marginEnd="8dp"
                    android:background="@drawable/frosted_card"
                    android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                              android:text="🕐" android:textSize="18sp"/>
                    <TextView android:id="@+id/tvAvgDur" android:layout_width="wrap_content"
                              android:layout_height="wrap_content" android:text="--"
                              android:textSize="18sp" android:textColor="@color/frost_white"
                              android:fontFamily="sans-serif-light"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                              android:text="Ср. длит." android:textSize="10sp"
                              android:textColor="@color/whisper_gray" android:fontFamily="sans-serif-light"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="90dp"
                    android:layout_weight="1" android:layout_marginEnd="8dp"
                    android:background="@drawable/frosted_card"
                    android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                              android:text="⭐" android:textSize="18sp"/>
                    <TextView android:id="@+id/tvAvgQuality" android:layout_width="wrap_content"
                              android:layout_height="wrap_content" android:text="--"
                              android:textSize="18sp" android:textColor="@color/frost_white"
                              android:fontFamily="sans-serif-light"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                              android:text="Ср. качество" android:textSize="10sp"
                              android:textColor="@color/whisper_gray" android:fontFamily="sans-serif-light"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="90dp"
                    android:layout_weight="1"
                    android:background="@drawable/frosted_card"
                    android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                              android:text="📋" android:textSize="18sp"/>
                    <TextView android:id="@+id/tvCount" android:layout_width="wrap_content"
                              android:layout_height="wrap_content" android:text="0"
                              android:textSize="18sp" android:textColor="@color/frost_white"
                              android:fontFamily="sans-serif-light"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                              android:text="Записей" android:textSize="10sp"
                              android:textColor="@color/whisper_gray" android:fontFamily="sans-serif-light"/>
                </LinearLayout>
            </LinearLayout>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                      android:text="ИСТОРИЯ" android:textSize="10sp" android:letterSpacing="0.15"
                      android:textColor="@color/whisper_gray" android:layout_marginBottom="12dp"
                      android:fontFamily="sans-serif"/>
            <LinearLayout android:id="@+id/llRecords" android:layout_width="match_parent"
                          android:layout_height="wrap_content" android:orientation="vertical"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
